<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#12121A"
    android:padding="24dp">

    <!-- Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Projector+"
        android:textSize="32sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/versionText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v1.0.4"
        android:textSize="14sp"
        android:textColor="#7A7A8A"
        android:layout_marginBottom="32dp" />

    <!-- Main Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp"
        android:background="@drawable/bg_card"
        android:elevation="8dp"
        android:gravity="center">

        <!-- Status Indicator -->
        <View
            android:id="@+id/statusDot"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/bg_btn_stop"
            android:backgroundTint="#AAAAAA"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ready to Connect"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/ipText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="IP: 192.168.x.x"
            android:textSize="15sp"
            android:textColor="#888899"
            android:layout_marginBottom="24dp" />

        <!-- Action Buttons -->
        <Button
            android:id="@+id/startButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="START MIRRORING"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_btn_start"
            android:layout_marginBottom="12dp"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/stopButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Disconnect"
            android:textSize="16sp"
            android:textColor="#BBBBCC"
            android:background="@drawable/bg_btn_stop"
            android:visibility="gone"
            android:stateListAnimator="@null" />

    </LinearLayout>

    <!-- Accessibility Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@drawable/bg_card"
        android:elevation="4dp"
        android:gravity="center"
        android:layout_marginTop="16dp">

        <TextView
            android:id="@+id/accessibilityStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠ Enable Accessibility for full control"
            android:textSize="14sp"
            android:textColor="#f59e0b"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/accessibilityBtn"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="ENABLE IN SETTINGS"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_btn_stop"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/unrestrictBtn"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:text="UNRESTRICT APP"
            android:textSize="13sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_btn_stop"
            android:stateListAnimator="@null" />

    </LinearLayout>

</LinearLayout>

